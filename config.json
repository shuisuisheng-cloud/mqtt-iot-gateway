{
    "project_name": "Linux-STM32 IoT Edge Gateway",
    "version": "v0.1",
    "author": "shuisuisheng",
    "port": "/dev/ttyUSB0",
    "baudrate": 115200,
    "device": "stm32_node_01",
    "use_real_serial":  false ,
    "temperature_threshold": 30,
    "mqtt_enabled": true,
    "mqtt_broker": "localhost",
    "mqtt_port": 1883,
    "mqtt_client_id":"linux_stm32_gateway_01",
    "mqtt_topic_prefix":"edgeaiot",
    "mqtt_keepalive":60,
    "heartbeat_interval": 10,
    "mqtt_reconnect_first_waiting_time":5,
    "mqtt_reconnect_max_waiting_time":30
}